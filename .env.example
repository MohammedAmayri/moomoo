RETELL_API_KEY=replace_me

# Optional: run npm run agent:voice -- <agent_id> to fill these from an existing agent.
RETELL_VOICE_ID=
RETELL_VOICE_MODEL=
RETELL_FALLBACK_VOICE_IDS=
RETELL_VOICE_SPEED=1
RETELL_VOICE_TEMPERATURE=1
RETELL_ENABLE_DYNAMIC_VOICE_SPEED=true
RETELL_VOLUME=1
RETELL_VOICE_EMOTION=

RETELL_AGENT_NAME=Swedish Direct Agent
RETELL_AGENT_DESCRIPTION=Swedish multi-state agent that is direct, skeptical, and respectful.
RETELL_LANGUAGE=sv-SE
RETELL_LLM_MODEL=gpt-4.1-mini
RETELL_BEGIN_MESSAGE=Vad vill du att vi tar itu med?

# Optional: switch an existing Retell agent from Retell LLM to a Grok-backed custom LLM bridge.
RETELL_AGENT_ID=replace_with_retell_agent_id
RETELL_LLM_WEBSOCKET_URL=wss://your-domain.example/llm-websocket/

# xAI / Grok bridge settings
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4.20
GROK_TEMPERATURE=0.2
GROK_BEGIN_MESSAGE=Jaha. Vad gäller det, mer exakt?
GROK_REMINDER_MESSAGE=Jaha. Fortsätt då, men gärna mer konkret den här gången.
